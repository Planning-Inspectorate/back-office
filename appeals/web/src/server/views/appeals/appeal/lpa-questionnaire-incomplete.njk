{%- extends "app/layouts/app.layout.njk" -%}

{%- from "govuk/components/checkboxes/macro.njk" import govukCheckboxes -%}
{%- from "govuk/components/button/macro.njk" import govukButton -%}
{%- from "govuk/components/input/macro.njk" import govukInput -%}
{%- from "../../app/components/add-another.njk" import addAnother -%}

{%- set pageTitle = "Why is the LPA questionnaire incomplete - GOV.UK" -%}

{%- set backLinkUrl -%}
	/appeals-service/appeal-details/{{ appeal.id }}/lpa-questionnaire/{{ lpaQuestionnaireId }}
{%- endset -%}

{%- block pageHeading -%}
	<div class="govuk-grid-row">
		<div class="govuk-grid-column-full">
			<span class="govuk-caption-l govuk-!-margin-bottom-3">Appeal {{ appeal.shortReference }}</span>
			<h1 class="govuk-heading-l govuk-!-margin-bottom-3">Why is the LPA questionnaire incomplete?</h1>
		</div>
	</div>
{%- endblock -%}

{%- block pageContent -%}
	{%- for option in reasonOptions -%}
		{%- if option.addAnother -%}
			{%- set addAnotherItems = [] -%}
			{%- for textItem in option.addAnother.textItems -%}
				{%- set inputHtml = govukInput({
						classes: 'govuk-!-margin-bottom-3 pins-add-another__item-input',
						name: 'incompleteReason-' + option.value,
						value: textItem
					})
				-%}
				{%- set _ = addAnotherItems.push(inputHtml) -%}
			{%- endfor -%}
			{%- set addAnotherHtml = addAnother({ items: addAnotherItems }) -%}
			{%- set _ = option | addConditionalHtml(addAnotherHtml) -%}
		{%- endif -%}
	{%- endfor -%}
	<form method="post" novalidate="novalidate">
		{{ govukCheckboxes({
			name: "incompleteReason",
			items: reasonOptions
		}) }}
		{{ govukButton({
			text: "Continue",
			type: "submit"
		}) }}
	</form>
{%- endblock -%}
