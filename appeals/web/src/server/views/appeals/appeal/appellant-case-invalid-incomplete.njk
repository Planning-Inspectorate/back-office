{%- extends "app/layouts/app.layout.njk" -%}

{%- from "govuk/components/checkboxes/macro.njk" import govukCheckboxes -%}
{%- from "govuk/components/textarea/macro.njk" import govukTextarea -%}
{%- from "govuk/components/button/macro.njk" import govukButton -%}
{%- from "govuk/components/input/macro.njk" import govukInput -%}
{%- from "../../app/components/add-another.njk" import addAnother -%}

{%- set pageTitle = "Why is the appeal " + notValidStatus + " - GOV.UK" -%}

{%- set backLinkUrl -%}
	/appeals-service/appeal-details/{{ appeal.id }}/appellant-case
{%- endset -%}

{%- set otherReasonHtml -%}
	{%- set otherReasonItems = [] -%}
	{%- if otherReason -%}
		{%- for reason in otherReason -%}
			{%- set _ = otherReasonItems.push(govukInput({
				classes: 'govuk-!-margin-bottom-3 pins-add-another__item-input',
				name: 'otherReason',
				value: reason
			})) -%}
		{%- endfor -%}
	{%- else -%}
		{%- set _ = otherReasonItems.push(govukInput({
			classes: 'govuk-!-margin-bottom-3 pins-add-another__item-input',
			name: 'otherReason'
		})) -%}
	{%- endif -%}
	{{ addAnother({
		items: otherReasonItems
	}) }}
{%- endset -%}

{%- block pageHeading -%}
	<div class="govuk-grid-row">
		<div class="govuk-grid-column-full">
			<span class="govuk-caption-l govuk-!-margin-bottom-3">Appeal {{ appeal.shortReference }}</span>
			<h1 class="govuk-heading-l govuk-!-margin-bottom-3">Why is the appeal {{ notValidStatus }}?</h1>
		</div>
	</div>
{%- endblock -%}

{%- block pageContent -%}
	<form method="post" novalidate="novalidate">
		{{ govukCheckboxes({
			name: notValidStatus + "Reason",
			items: reasonOptions | checkboxItemParameterAddConditionalHtml('text', 'Other', otherReasonHtml)
		}) }}
		{{ govukButton({
			text: "Continue",
			type: "submit"
		}) }}
		<input type="hidden" id="otherReasonId" name="otherReasonId" value="{{ otherReasonId }}" />
	</form>
{%- endblock -%}
