{%- extends "app/layouts/app.layout.njk" -%}

{%- from "govuk/components/checkboxes/macro.njk" import govukCheckboxes -%}
{%- from "govuk/components/button/macro.njk" import govukButton -%}
{%- from "govuk/components/input/macro.njk" import govukInput -%}
{%- from "../../app/components/add-another.njk" import addAnother -%}

{%- set pageTitle = "Why is the appeal " + notValidStatus + " - GOV.UK" -%}

{%- set backLinkUrl -%}
	/appeals-service/appeal-details/{{ appeal.id }}/appellant-case
{%- endset -%}

{%- block pageHeading -%}
	<div class="govuk-grid-row">
		<div class="govuk-grid-column-full">
			<span class="govuk-caption-l govuk-!-margin-bottom-3">Appeal {{ appeal.shortReference }}</span>
			<h1 class="govuk-heading-l govuk-!-margin-bottom-3">Why is the appeal {{ notValidStatus }}?</h1>
		</div>
	</div>
{%- endblock -%}

{%- block pageContent -%}

	{# add "add another" as conditional html on each checkbox option which hasText #}
	{%- for option in reasonOptions -%}
		{%- if option.hasText -%}
			{# build "add another" html #}
			{# don't worry about existing items for now - can do those once basic version is working #}
			{%- set addAnotherHtml = addAnother({ items: [govukInput({classes: 'govuk-!-margin-bottom-3 pins-add-another__item-input', name: notValidStatus + 'Reason-' + option.value, value: reason})] }) -%}
			{# assign built html to conditional property of option #}
			{%- set _ = option | addConditionalHtml(addAnotherHtml) -%}
		{%- endif -%}
	{%- endfor -%}

	<form method="post" novalidate="novalidate">
		{{ govukCheckboxes({
			name: notValidStatus + "Reason",
			items: reasonOptions
		}) }}
		{{ govukButton({
			text: "Continue",
			type: "submit"
		}) }}
		<input type="hidden" id="otherReasonId" name="otherReasonId" value="{{ otherReasonId }}" />
	</form>
{%- endblock -%}
