{% extends "applications/layouts/applications.layout.njk" %}

{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from 'app/components/file-uploader.component.njk' import fileUploader %}

{% set pageTitle = "Phase 2 Upsert Bug — POC" %}

{% block pageHeading %}
	<h1 class="govuk-heading-l">{{ pageTitle }}</h1>
{% endblock %}

{% block pageContent %}

	{% if apiError %}
		<div class="govuk-error-summary" data-module="govuk-error-summary">
			<h2 class="govuk-error-summary__title">API Error during "{{ apiError.step }}" step</h2>
			<div class="govuk-error-summary__body">
				<p class="govuk-body">{{ apiError.message }}</p>
			</div>
		</div>
	{% endif %}

	{# ─── PAGE 1: Main form ─── #}
	{% if page == 'main' %}
		<div class="govuk-grid-row">
			<div class="govuk-grid-column-two-thirds">
				<p class="govuk-body">This POC demonstrates that <strong>Phase 2</strong> of the document upload process (<code>upsertDocumentVersionsMetadataToDatabase</code>) silently wipes metadata fields set by <strong>Phase 1</strong> (<code>attemptInsertDocuments</code>).</p>

				<details class="govuk-details">
					<summary class="govuk-details__summary">
						<span class="govuk-details__summary-text">How the bug works</span>
					</summary>
					<div class="govuk-details__text">
						<ol class="govuk-list govuk-list--number">
							<li><strong>Phase 1</strong>: Creates DocumentVersion with full metadata (stage, filter1, author, mime, size, etc.)</li>
							<li><strong>Phase 2</strong>: Resolves blob storage location, then calls <code>upsert()</code> with ONLY <code>{ privateBlobContainer, documentGuid, privateBlobPath }</code></li>
							<li>Prisma's upsert <code>update</code> clause spreads <code>...metadata</code> — since metadata only has blob fields, all other fields are reset to null</li>
						</ol>
						<p class="govuk-body"><strong>Tip:</strong> Upload to a folder under "Project documentation" (e.g. Acceptance) to see the full bug — those folders enrich filter1 and author in Phase 1.</p>
					</div>
				</details>
			</div>
		</div>

		<form method="POST" novalidate>
			<div class="govuk-grid-row">
				<div class="govuk-grid-column-two-thirds">

					{{ govukInput({
						label: { text: "Case ID", classes: "govuk-label--m" },
						hint: { text: "e.g. 100000085" },
						id: "caseId",
						name: "caseId",
						errorMessage: errors.caseId and { text: errors.caseId }
					}) }}

					{{ govukInput({
						label: { text: "Folder ID", classes: "govuk-label--m" },
						hint: { text: "e.g. 100011268" },
						id: "folderId",
						name: "folderId",
						errorMessage: errors.folderId and { text: errors.folderId }
					}) }}

					{{ govukButton({ text: "Continue" }) }}

				</div>
			</div>
		</form>
	{% endif %}

	{# ─── PAGE 2: File upload ─── #}
	{% if page == 'file-upload' %}
		<a href="/applications-service/poc/file-props-wipe" class="govuk-back-link">Back</a>

		<div class="govuk-grid-row govuk-!-margin-bottom-6">
			<div class="govuk-grid-column-two-thirds">
				<details class="govuk-details">
					<summary class="govuk-details__summary">
						<span class="govuk-details__summary-text">Duplicate file error?</span>
					</summary>
					<div class="govuk-details__text">
						<p class="govuk-body"><strong>Note:</strong> The API rejects filenames that have been used before on this case, even after deletion. You must use a different filename each time.</p>
						<p class="govuk-body">The button below deletes the most recent document in the folder (useful for cleanup):</p>
						<form method="POST" action="/applications-service/poc/file-props-wipe/file-upload">
							<input type="hidden" name="caseId" value="{{ caseId }}">
							<input type="hidden" name="folderId" value="{{ folderId }}">
							{{ govukButton({
								text: "Delete most recent file in folder",
								classes: "govuk-button--warning"
							}) }}
						</form>
					</div>
				</details>
			</div>
		</div>

		{{ fileUploader({
			text: 'Upload file',
			formId: 'poc-wipe',
			caseId: caseId,
			folderId: folderId,
			formTitle: 'Upload any file (use a unique filename)',
			nextPageUrl: '/applications-service/poc/file-props-wipe/result?caseId=' + caseId + '&folderId=' + folderId,
			allowedTypes: ['dbf','doc','docx','html','jpeg','jpg','mov','mp3','mp4','mpeg','msg','pdf','png','ppt','pptx','prj','shp','shx','tif','tiff','xls','xlsm','xlsx','zip'],
			showUploadLabel: true,
			multiple: false
		}) }}
	{% endif %}

	{# ─── PAGE 3: Results ─── #}
	{% if page == 'result' and results %}

		{# Verdict Banner #}
		{% if results.bugReproduced %}
			<div class="govuk-panel govuk-panel--confirmation" style="background-color: #d4351c;">
				<h2 class="govuk-panel__title">Bug Confirmed</h2>
				<div class="govuk-panel__body">
					Phase 2 wiped {{ results.wipedFields | length }} metadata field(s) that Phase 1 set.
				</div>
			</div>
		{% else %}
			<div class="govuk-panel govuk-panel--confirmation" style="background-color: #00703c;">
				<h2 class="govuk-panel__title">Bug NOT Reproduced</h2>
				<div class="govuk-panel__body">
					No metadata fields were wiped. Try uploading to a folder under "Project documentation" to see the full bug.
				</div>
			</div>
		{% endif %}

		<hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

		<h2 class="govuk-heading-m">Document: {{ results.documentGuid }} (version {{ results.version }})</h2>
		<p class="govuk-body">Folder path: <strong>{{ results.folderPath }}</strong></p>

		{% if not results.isAppDocsFolder %}
			<div class="govuk-warning-text">
				<span class="govuk-warning-text__icon" aria-hidden="true">!</span>
				<strong class="govuk-warning-text__text">
					This folder is not under "Project documentation" — Phase 1 does not enrich filter1/author for this folder. Try a folder under Project documentation to see the full bug.
				</strong>
			</div>
		{% endif %}

		<h3 class="govuk-heading-s">Field Comparison: Phase 1 (expected) vs Actual (after Phase 2)</h3>
		<table class="govuk-table">
			<thead class="govuk-table__head">
				<tr class="govuk-table__row">
					<th class="govuk-table__header" scope="col">Field</th>
					<th class="govuk-table__header" scope="col">Phase 1 (expected)</th>
					<th class="govuk-table__header" scope="col">Actual (after Phase 2)</th>
					<th class="govuk-table__header" scope="col">Status</th>
				</tr>
			</thead>
			<tbody class="govuk-table__body">
				{% for row in results.comparison %}
					{% set isWiped = false %}
					{% for w in results.wipedFields %}
						{% if w.field == row.field %}
							{% set isWiped = true %}
						{% endif %}
					{% endfor %}
					<tr class="govuk-table__row">
						<th class="govuk-table__header" scope="row">{{ row.label }}</th>
						<td class="govuk-table__cell">{{ row.phase1 if row.phase1 else "—" }}</td>
						<td class="govuk-table__cell" {% if isWiped %}style="background-color: #f3e1e1;"{% endif %}>
							{{ row.actual if row.actual !== null and row.actual !== undefined else "null" }}
						</td>
						<td class="govuk-table__cell">
							{% if row.setByPhase2 %}
								<strong class="govuk-tag govuk-tag--blue">SET BY PHASE 2</strong>
							{% elif isWiped %}
								<strong class="govuk-tag govuk-tag--red">WIPED BY PHASE 2</strong>
							{% elif row.survivesPhase2 %}
								<strong class="govuk-tag govuk-tag--green">SURVIVED</strong>
							{% elif row.actual !== null and row.actual !== undefined and row.actual !== '' %}
								<strong class="govuk-tag govuk-tag--green">OK</strong>
							{% else %}
								<strong class="govuk-tag govuk-tag--grey">NOT SET</strong>
							{% endif %}
						</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>

		{# Explanation #}
		{% if results.bugReproduced %}
			<div class="govuk-inset-text">
				<h3 class="govuk-heading-s">Root Cause</h3>
				<p class="govuk-body"><code>upsertDocumentVersionsMetadataToDatabase()</code> in <code>document.service.js</code> calls <code>documentVersionRepository.upsert()</code> with only <code>{ privateBlobContainer, documentGuid, privateBlobPath }</code>. The Prisma upsert's <code>update</code> clause spreads this partial payload, resetting all other fields to null.</p>
				<h3 class="govuk-heading-s">Fix</h3>
				<p class="govuk-body">Replace the Phase 2 <code>upsert()</code> with a targeted <code>update()</code> that only writes <code>privateBlobContainer</code> and <code>privateBlobPath</code>.</p>
			</div>
		{% endif %}

		<a href="/applications-service/poc/file-props-wipe" class="govuk-link govuk-!-margin-top-6">Start again</a>
	{% endif %}

{% endblock %}
