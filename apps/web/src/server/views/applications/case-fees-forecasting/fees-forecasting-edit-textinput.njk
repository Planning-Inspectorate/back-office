{% extends "../layouts/applications.layout.njk" %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block beforeContent %}
	<aside>
		{{ govukBackLink({
			text: "Back",
			href: 'fees-forecasting'|url({caseId: caseId})
		}) }}
	</aside>
{% endblock %}

{% block pageHeading %}
	<h1 class="govuk-heading-l">{{ pageHeading }}</h1>
{% endblock %}

{% block pageContent %}
	<form method="post" novalidate="novalidate" class="govuk-grid-row">
		<div class='govuk-grid-column-two-thirds'>
			{{ govukInput({
				name: fieldName,
				errorMessage: errors[fieldName] and {
					text: errors[fieldName].msg
				},
				value: values[fieldName]
			}) }}

			{{ govukButton({ text: 'Save and return' }) }}
		</div>
	</form>

{% endblock %}
